---
import { CF_IMAGES, cfImageUrl, ACQUISITION_MAILTO } from '../config/site';

const secondaryBg = cfImageUrl(CF_IMAGES.secondaryImageId);
---

<!-- Why This Domain -->
<section id="why" class="py-20 md:py-28 border-b border-white/10 creative-grid">
  <div class="max-w-5xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="font-display text-3xl md:text-4xl tracking-tight mb-4">A Name That Speaks to the World</h2>
      <p class="text-lg text-zinc-400 max-w-2xl mx-auto">
        Sueno De Playa — "Beach Dream" in Spanish — is one of the most evocative and universally 
        appealing domain names on the market. It carries instant emotional resonance across languages and cultures.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <div class="premium-card rounded-2xl border border-white/10 bg-white/[0.02] p-8">
        <div class="w-12 h-12 rounded-xl bg-cyan-500/10 flex items-center justify-center mb-5">
          <i class="fa-solid fa-globe text-2xl text-cyan-400"></i>
        </div>
        <h3 class="font-display text-xl mb-3">Cross-Cultural Appeal</h3>
        <p class="text-zinc-400 leading-relaxed">
          Spanish and English speakers alike instantly understand the aspirational 
          promise — a dream of the beach, a vision of paradise.
        </p>
      </div>

      <div class="premium-card rounded-2xl border border-white/10 bg-white/[0.02] p-8">
        <div class="w-12 h-12 rounded-xl bg-teal-500/10 flex items-center justify-center mb-5">
          <i class="fa-solid fa-umbrella-beach text-2xl text-teal-400"></i>
        </div>
        <h3 class="font-display text-xl mb-3">Lifestyle Brand Ready</h3>
        <p class="text-zinc-400 leading-relaxed">
          Perfect for a luxury beach resort, travel platform, coastal real estate brand, 
          wellness retreat, or premium lifestyle publication.
        </p>
      </div>

      <div class="premium-card rounded-2xl border border-white/10 bg-white/[0.02] p-8">
        <div class="w-12 h-12 rounded-xl bg-amber-500/10 flex items-center justify-center mb-5">
          <i class="fa-solid fa-chart-line text-2xl text-amber-400"></i>
        </div>
        <h3 class="font-display text-xl mb-3">Scarce .Com Equity</h3>
        <p class="text-zinc-400 leading-relaxed">
          Premium .com domains with this level of linguistic and emotional resonance 
          are vanishingly rare. Own the definitive digital beachfront property.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Opportunity Section -->
<section id="opportunity" class="py-20 md:py-28 border-b border-white/10">
  <div class="max-w-5xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <div class="inline-flex items-center gap-x-2 px-4 py-1.5 rounded-3xl bg-amber-500/10 border border-amber-500/20 mb-6">
          <i class="fa-solid fa-lightbulb text-amber-400 text-xs"></i>
          <span class="text-xs font-medium tracking-[1.5px] text-amber-400">STRATEGIC OPPORTUNITY</span>
        </div>
        <h2 class="font-display text-3xl md:text-4xl tracking-tight mb-6">
          Capitalize on the $1.4T Global Tourism Economy
        </h2>
        <p class="text-zinc-400 leading-relaxed mb-4">
          Global tourism is projected to surpass $1.4 trillion in 2026, with beach and coastal 
          destinations commanding the highest traveler intent. A premium domain like SuenoDePlaya.com 
          positions your brand at the center of this massive market.
        </p>
        <p class="text-zinc-400 leading-relaxed mb-6">
          Whether you're launching a luxury travel booking platform, a coastal real estate marketplace, 
          a resort brand, or a lifestyle content empire — this domain delivers instant authority, 
          trust, and global recognition.
        </p>
        <a
          href={ACQUISITION_MAILTO}
          class="inline-flex items-center gap-x-3 px-8 py-4 bg-gradient-to-r from-cyan-500 to-teal-500 text-white font-semibold rounded-2xl hover:brightness-110 transition-all shadow-lg shadow-cyan-500/20"
        >
          <span>Inquire About This Domain</span>
          <i class="fa-solid fa-arrow-right"></i>
        </a>
      </div>

      <div class="relative">
        <div
          class="rounded-3xl overflow-hidden border border-white/10 coastal-glow"
          style="aspect-ratio: 4/3;"
        >
          <div
            class="w-full h-full hero-image"
            style="background-image: url('{secondaryBg}');"
          ></div>
        </div>
        <div class="absolute -bottom-4 -right-4 w-full h-full rounded-3xl border border-cyan-500/15 bg-gradient-to-br from-cyan-500/5 to-teal-500/5 -z-10" aria-hidden="true"></div>
      </div>
    </div>
  </div>
</section>

<!-- Acquire CTA -->
<section id="acquire" class="py-20 md:py-28 creative-grid">
  <div class="max-w-5xl mx-auto px-6">
    <div class="relative overflow-hidden rounded-3xl border border-cyan-500/25 bg-gradient-to-br from-zinc-900 via-black to-teal-950/40 p-8 sm:p-14 text-center">
      <div
        class="absolute -top-24 -right-24 w-64 h-64 rounded-full bg-cyan-500/10 blur-3xl pointer-events-none"
        aria-hidden="true"
      ></div>
      <div
        class="absolute -bottom-24 -left-24 w-64 h-64 rounded-full bg-teal-500/10 blur-3xl pointer-events-none"
        aria-hidden="true"
      ></div>

      <div class="relative z-10">
        <p class="text-xs uppercase tracking-[3px] text-cyan-400 font-extrabold mb-6">Domain Available for Acquisition</p>
        <h2 class="font-display text-3xl md:text-5xl tracking-tight mb-6">
          SuenoDePlaya.com —<br class="hidden sm:block" />Your Digital Beachfront
        </h2>
        <p class="text-zinc-400 max-w-2xl mx-auto leading-relaxed mb-10">
          This domain is positioned at the intersection of luxury travel, coastal lifestyle, 
          and aspirational branding. A rare strategic asset for the visionary buyer. 
          Serious inquiries only — pricing, transfer logistics, and escrow options available upon request.
        </p>

        <div class="inline-flex flex-col items-center gap-y-4">
          <a
            href={ACQUISITION_MAILTO}
            class="group inline-flex items-center justify-center gap-x-3 px-10 py-5 text-lg font-extrabold rounded-2xl bg-gradient-to-r from-cyan-500 via-teal-500 to-amber-500 text-white hover:brightness-110 transition-all shadow-xl shadow-cyan-500/25"
          >
            <i class="fa-solid fa-envelope"></i>
            <span>sales@desertrich.com</span>
            <i class="fa-solid fa-arrow-right group-hover:translate-x-1 transition-transform"></i>
          </a>
          <p class="text-xs text-zinc-500 tracking-wide">Confidential inquiries • Response within 24 hours</p>
        </div>
      </div>
    </div>
  </div>
</section>
