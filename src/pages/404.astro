---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout canonicalPath="/404/">
  <meta slot="head" name="robots" content="noindex" />
  <section class="flex min-h-[70vh] items-center justify-center px-4 text-center">
    <div class="max-w-lg">
      <p class="text-6xl font-bold text-cyan-400">404</p>
      <h1 class="mt-4 text-2xl font-bold text-white sm:text-3xl">
        Page Not Found
      </h1>
      <p class="mt-4 text-base leading-relaxed text-white/70">
        The page you are looking for does not exist. It may have been moved or
        the address was typed incorrectly.
      </p>
      <a
        href="/"
        class="mt-8 inline-block rounded-lg bg-cyan-500 px-6 py-3 text-sm font-bold uppercase tracking-wide text-white transition hover:bg-cyan-400"
      >
        Return Home
      </a>
    </div>
  </section>
</BaseLayout>
